# In-memory factory state (RAM). Optional Postgres for auth + per-project LLM profile.
DATABASE_URL=

# NextAuth v5 — обязателен в production (`next start`, Vercel). В `next dev` при пустом значении подставляется dev-fallback из кода.
# Сгенерировать: openssl rand -base64 32
AUTH_SECRET=
# Опционально; для локального dev обычно не нужен при trustHost в коде
AUTH_URL=http://localhost:3000

# Google OAuth (optional). Redirect: https://<host>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- LLM (глобальный fallback через env; при DATABASE_URL + логине приоритет у профиля проекта в UI /settings/llm) ---
# LLM_PROVIDER: mock | openai | neurohub
# mock — детерминированный чертёж без сети.
# openai / neurohub — один и тот же HTTP-клиент: OpenAI-compatible POST {baseUrl}/chat/completions, заголовок Authorization: Bearer <apiKey>.
LLM_PROVIDER=mock

# OpenAI (или любой совместимый хост с путём /v1)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Neurohub (нейрохаб, OpenAI-compatible chat completions)
# Опционально: таймауты исходящего HTTP к LLM (мс). Дефолт connect ~60s (Node иначе рвёт ~10s).
# LLM_CONNECT_TIMEOUT_MS=60000
# LLM_HEADERS_TIMEOUT_MS=180000
# LLM_BODY_TIMEOUT_MS=180000
# Быстрый GET к origin перед chat/completions (connect timeout, мс). Раньше видно «хост недоступен».
# LLM_PREFLIGHT_CONNECT_TIMEOUT_MS=8000
# Попробовать stream: true перед обычным JSON (два запроса к тому же хосту; при ConnectTimeout второй не вызывается).
# По умолчанию выключено — один POST к chat/completions. Включить: LLM_TRY_STREAMING_BLUEPRINT=1
# LLM_TRY_STREAMING_BLUEPRINT=1
# Лог этапов чертежа в stdout (journalctl -u c-fab-app -f). Отключить: LLM_PROGRESS_LOG=0
# LLM_PROGRESS_LOG=0
# Официальный боевой base для клиента (из onboarding Neurohub): https://ai.nova01.click/neurohub/v1
# Код шлёт POST на {NEUROHUB_BASE_URL}/chat/completions + Authorization: Bearer <NEUROHUB_API_KEY>.
# Модель — как в их доке, напр. Qwen/Qwen3.5-27B (подставь своё значение).
#
# Важно: при LLM_PROVIDER=neurohub в коде сначала берётся NEUROHUB_API_KEY, потом OPENAI_API_KEY как запасной;
# при LLM_PROVIDER=openai — наоборот. Оба ключа в одном .env не конфликтуют.
# URL вида http://127.0.0.1:6006 из доки Neurohub — это шлюз только на машине mag-01; на другом сервере 127.0.0.1 — не тот Neurohub.
# Если curl с nova-02 до https://ai.nova01.click таймаутится — открой файрвол / маршрут с IP nova-02 к хосту шлюза или используй приватный URL (VPN, tailnet, внутренний IP mag-01).
NEUROHUB_API_KEY=
NEUROHUB_BASE_URL=
NEUROHUB_MODEL=

FACTORY_SEED=42

DEFAULT_DAILY_BUDGET_USD=50
