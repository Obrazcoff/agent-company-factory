# In-memory factory state (RAM). Optional Postgres for auth + per-project LLM profile.
DATABASE_URL=

# NextAuth v5 — обязателен в production (`next start`, Vercel). В `next dev` при пустом значении подставляется dev-fallback из кода.
# Сгенерировать: openssl rand -base64 32
AUTH_SECRET=
# Опционально; для локального dev обычно не нужен при trustHost в коде
AUTH_URL=http://localhost:3000

# Google OAuth (optional). Redirect: https://<host>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- LLM (глобальный fallback через env; при DATABASE_URL + логине приоритет у профиля проекта в UI /settings/llm) ---
# LLM_PROVIDER: mock | openai | neurohub
# mock — детерминированный чертёж без сети.
# openai / neurohub — один и тот же HTTP-клиент: OpenAI-compatible POST {baseUrl}/chat/completions, заголовок Authorization: Bearer <apiKey>.
LLM_PROVIDER=mock

# OpenAI (или любой совместимый хост с путём /v1)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Neurohub (нейрохаб): нужны те же три сущности, что и у OpenAI-совместимого API
# 1) NEUROHUB_BASE_URL — база до /v1 включительно (пример: https://api.your-neurohub.ru/v1). Код сам добавит /chat/completions.
# 2) NEUROHUB_API_KEY — токен, который хаб ожидает в Authorization: Bearer …
# 3) NEUROHUB_MODEL — идентификатор модели на стороне хаба (как в их доке, напр. qwen-…).
NEUROHUB_API_KEY=
NEUROHUB_BASE_URL=
NEUROHUB_MODEL=

FACTORY_SEED=42

DEFAULT_DAILY_BUDGET_USD=50
